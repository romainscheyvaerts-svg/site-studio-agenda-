# =============================================================================
# MAKE MUSIC STUDIO - Variables d'environnement pour Vercel
# =============================================================================
# Ce fichier liste toutes les variables nécessaires pour le déploiement.
# Copiez ce fichier en .env.local pour le développement local.
# Sur Vercel, configurez ces variables dans Settings > Environment Variables.
# =============================================================================

# -----------------------------------------------------------------------------
# SUPABASE - Base de données et authentification
# -----------------------------------------------------------------------------
# Ces variables sont utilisées côté frontend (client Vite)
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
VITE_SUPABASE_PROJECT_ID=your-project-id

# -----------------------------------------------------------------------------
# SUPABASE EDGE FUNCTIONS - Variables serveur (secrets)
# -----------------------------------------------------------------------------
# Ces variables doivent être configurées dans Supabase Dashboard > Edge Functions > Secrets
# Ou via CLI: supabase secrets set VARIABLE_NAME=value

# URL Supabase (automatiquement disponible dans les Edge Functions)
# SUPABASE_URL=https://your-project-id.supabase.co

# Clé Service Role - ATTENTION: Ne jamais exposer côté client!
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Clé Anon (publique)
# SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# -----------------------------------------------------------------------------
# STRIPE - Paiements par carte
# -----------------------------------------------------------------------------
# Dashboard: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_... ou sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_live_... ou pk_test_...

# -----------------------------------------------------------------------------
# PAYPAL - Paiements alternatifs
# -----------------------------------------------------------------------------
# Dashboard: https://developer.paypal.com/dashboard/applications
PAYPAL_CLIENT_ID=votre-client-id
PAYPAL_CLIENT_SECRET=votre-client-secret

# -----------------------------------------------------------------------------
# RESEND - Envoi d'emails
# -----------------------------------------------------------------------------
# Dashboard: https://resend.com/api-keys
RESEND_API_KEY=re_...

# Email d'expédition (doit être vérifié dans Resend)
RESEND_FROM_EMAIL=noreply@studiomakemusic.com

# Email admin pour les notifications
ADMIN_EMAIL=prod.makemusic@gmail.com

# -----------------------------------------------------------------------------
# GOOGLE - Service Account pour Calendar, Drive, etc.
# -----------------------------------------------------------------------------
# Console: https://console.cloud.google.com/iam-admin/serviceaccounts
# Le contenu JSON du fichier clé du compte de service (minifié sur une ligne)
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@...iam.gserviceaccount.com","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"..."}

# ID du calendrier Google principal du studio
GOOGLE_STUDIO_CALENDAR_ID=your-studio-calendar@group.calendar.google.com

# ID du calendrier personnel du patron (pour vérifier disponibilité)
GOOGLE_PATRON_CALENDAR_ID=patron-email@gmail.com

# IDs de calendriers secondaires (optionnel)
GOOGLE_SECONDARY_CALENDAR_ID=
GOOGLE_TERTIARY_CALENDAR_ID=

# URL iCal externe (Claridge ou autre)
CLARIDGE_ICAL_URL=webcal://...

# ID du dossier Google Drive parent pour les clients
GOOGLE_DRIVE_PARENT_FOLDER_ID=1AXGpSHUP0OyY2tWvCk573xb--Dj2jvLh

# -----------------------------------------------------------------------------
# LOVABLE AI - Chatbot et assistant devis
# -----------------------------------------------------------------------------
# Clé API pour le gateway AI de Lovable
LOVABLE_API_KEY=votre-cle-api-lovable

# =============================================================================
# CONFIGURATION SUPABASE EDGE FUNCTIONS SECRETS
# =============================================================================
# Pour configurer les secrets des Edge Functions, utilisez la CLI Supabase:
#
# supabase secrets set STRIPE_SECRET_KEY=sk_live_...
# supabase secrets set STRIPE_PUBLISHABLE_KEY=pk_live_...
# supabase secrets set PAYPAL_CLIENT_ID=...
# supabase secrets set PAYPAL_CLIENT_SECRET=...
# supabase secrets set RESEND_API_KEY=re_...
# supabase secrets set RESEND_FROM_EMAIL=noreply@studiomakemusic.com
# supabase secrets set ADMIN_EMAIL=prod.makemusic@gmail.com
# supabase secrets set GOOGLE_SERVICE_ACCOUNT_KEY='{"type":"service_account",...}'
# supabase secrets set GOOGLE_STUDIO_CALENDAR_ID=...
# supabase secrets set GOOGLE_PATRON_CALENDAR_ID=...
# supabase secrets set GOOGLE_SECONDARY_CALENDAR_ID=...
# supabase secrets set GOOGLE_TERTIARY_CALENDAR_ID=...
# supabase secrets set CLARIDGE_ICAL_URL=...
# supabase secrets set GOOGLE_DRIVE_PARENT_FOLDER_ID=...
# supabase secrets set LOVABLE_API_KEY=...
#
# Pour voir les secrets configurés:
# supabase secrets list
# =============================================================================
